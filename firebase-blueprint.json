{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Technician profile and app settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "fonction": { "type": "string" },
        "legalStatus": { "type": "string", "enum": ["auto-entrepreneur", "registre-commerce"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "nif": { "type": "string" },
        "registreCommerce": { "type": "string" },
        "carteAutoentrepreneur": { "type": "string" },
        "socialSecurity": { "type": "string" },
        "bankAccount": { "type": "string" },
        "signatureUrl": { "type": "string" },
        "stampUrl": { "type": "string" },
        "pinCode": { "type": "string" },
        "defaultCurrency": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "nif", "legalStatus"]
    },
    "Client": {
      "title": "Client",
      "description": "Client information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "nif": { "type": "string" },
        "nis": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string" },
        "projectName": { "type": "string" },
        "clientId": { "type": "string" },
        "technicianId": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "taxRate": { "type": "number" },
        "tvaRate": { "type": "number" },
        "isTvaNegative": { "type": "boolean" },
        "totalDays": { "type": "number" },
        "subTotal": { "type": "number" },
        "taxAmount": { "type": "number" },
        "tvaAmount": { "type": "number" },
        "total": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "invoiceNumber", "date", "projectName", "clientId", "technicianId", "status", "total"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/clients/{clientId}": {
      "schema": "Client",
      "description": "User's clients"
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "User's invoices"
    }
  }
}
